  m_Script: {fileID: 11500000, guid: 08581a2f1470ce54da4c5351f1009a4d, type: 3}
  m_Name: Find_big_mushroom
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  lines:
  - speaker: {fileID: 11400000, guid: 12c69f84337aa264598d4408de0e577a, type: 2}
    text: 'I feel very hungry. '
  - speaker: {fileID: 11400000, guid: 0c7e8b428f169b0458a27d977d3ce387, type: 2}
    text: Uhh then eat something?
  - speaker: {fileID: 11400000, guid: 12c69f84337aa264598d4408de0e577a, type: 2}
    text: I don't have anything on me right now. How about you find me something?
  - speaker: {fileID: 11400000, guid: 0c7e8b428f169b0458a27d977d3ce387, type: 2}
    text: Yeah what exactly can we find here?
  - speaker: {fileID: 11400000, guid: 12c69f84337aa264598d4408de0e577a, type: 2}
    text: Mushrooms, but i want a big one. Can you find a big mushroom for me?
  - speaker: {fileID: 11400000, guid: 12c69f84337aa264598d4408de0e577a, type: 2}
    text: And please cook it in the campfire too while you're at it, thanks!
