  m_Script: {fileID: 11500000, guid: 08581a2f1470ce54da4c5351f1009a4d, type: 3}
  m_Name: First_Greeting_Leave
  m_EditorClassIdentifier: Assembly-CSharp::DialougeSO
  lines:
  - speaker: {fileID: 11400000, guid: 12c69f84337aa264598d4408de0e577a, type: 2}
    text: Oh that's fine as well. But if you ever need help be sure to ask me.
  - speaker: {fileID: 11400000, guid: 0c7e8b428f169b0458a27d977d3ce387, type: 2}
    text: For sure chief. I'll take my leave then.
  - speaker: {fileID: 11400000, guid: 12c69f84337aa264598d4408de0e577a, type: 2}
    text: Take care warrior, may the blessings of the forest be with you.
