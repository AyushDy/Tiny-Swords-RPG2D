  m_Script: {fileID: 11500000, guid: 08581a2f1470ce54da4c5351f1009a4d, type: 3}
  m_Name: First _Greeting_Ask_him_Refuse
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  lines:
  - speaker: {fileID: 11400000, guid: 0c7e8b428f169b0458a27d977d3ce387, type: 2}
    text: I'm sorry chief but I don't think I have the time to hunt gobline right
      now.
  - speaker: {fileID: 11400000, guid: 0c7e8b428f169b0458a27d977d3ce387, type: 2}
    text: I am a little tight on time right now. I will come back again to help you
      when I'm done with my current task.
  - speaker: {fileID: 11400000, guid: 12c69f84337aa264598d4408de0e577a, type: 2}
    text: Hoho that's fine too warrior, take care then. May the blessings of the
      forest be with you.
  options: []
