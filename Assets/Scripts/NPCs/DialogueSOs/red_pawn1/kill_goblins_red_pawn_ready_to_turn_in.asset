  lines:
  - speaker: {fileID: 11400000, guid: 0c7e8b428f169b0458a27d977d3ce387, type: 2}
    text: I have finished dealing with the goblins.
  - speaker: {fileID: 11400000, guid: 9458f67f04adad1429d3d0bf16c5dfbd, type: 2}
    text: That's great news! The forest should be a bit safer now.
  - speaker: {fileID: 11400000, guid: 9458f67f04adad1429d3d0bf16c5dfbd, type: 2}
    text: Here.., take this payment.
